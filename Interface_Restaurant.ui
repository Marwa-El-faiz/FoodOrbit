QDialog { background-color: #F4F6F0; font-family: 'Segoe UI', sans-serif; }
#sidebar { background-color: #2D6A4F; }
#labelLogo { color: #FFFFFF; font-size: 20px; font-weight: bold; padding: 10px; }
#labelSub { color: #B7E4C7; font-size: 11px; padding-bottom: 10px; }
#btnNavPlats, #btnNavCategories, #btnNavCommandes, #btnNavMenu, #btnNavStatistiques, #btnNavPlanning {
    background-color: transparent; color: #D8F3DC; border: none;
    text-align: left; padding: 12px 20px; font-size: 14px;
    border-radius: 8px; margin: 2px 8px;
}
#btnNavPlats:hover, #btnNavCategories:hover, #btnNavCommandes:hover, #btnNavMenu:hover, #btnNavStatistiques:hover, #btnNavPlanning:hover {
    background-color: #40916C; color: #FFFFFF;
}
#btnNavPlats:checked, #btnNavCategories:checked, #btnNavCommandes:checked, #btnNavMenu:checked, #btnNavStatistiques:checked, #btnNavPlanning:checked {
    background-color: #1B4332; color: #FFFFFF; font-weight: bold;
}
#headerPlats, #headerCategories, #headerCommandes, #headerMenu, #headerStatistiques {
    background-color: #2D6A4F; border-radius: 10px; padding: 5px;
}
#labelTitrePlats, #labelTitreCategories, #labelTitreCommandes, #labelTitreMenu, #labelTitreStatistiques {
    color: #FFFFFF; font-size: 18px; font-weight: bold; padding-left: 10px;
}
QTableWidget { background-color: #FFFFFF; border: 1px solid #D8EDDF; border-radius: 8px; gridline-color: #E9F5EC; font-size: 13px; color: #1B4332; }
QTableWidget::item { padding: 6px; color: #1B4332; }
QTableWidget::item:selected { background-color: #B7E4C7; color: #1B4332; }
QHeaderView::section { background-color: #40916C; color: white; font-weight: bold; padding: 8px; border: none; font-size: 13px; }
#frameFormulairePlat, #frameFormulaireCategorie { background-color: #FFFFFF; border: 1px solid #D8EDDF; border-radius: 10px; }
QLineEdit { border: 1.5px solid #B7E4C7; border-radius: 6px; padding: 7px 10px; background: #F8FFF9; font-size: 13px; color: #1B4332; }
QLineEdit:focus { border-color: #2D6A4F; background: #FFFFFF; }
QComboBox { border: 1.5px solid #B7E4C7; border-radius: 6px; padding: 7px 10px; background: #F8FFF9; font-size: 13px; color: #1B4332; }
QComboBox:focus { border-color: #2D6A4F; }
QComboBox::drop-down { border: none; width: 20px; }
QComboBox QAbstractItemView { background: #FFFFFF; color: #1B4332; selection-background-color: #B7E4C7; selection-color: #1B4332; border: 1px solid #B7E4C7; font-size: 13px; }
QCheckBox { font-size: 13px; color: #2D6A4F; font-weight: bold; }
#labelImagePlat, #labelImageCategorie { border: 2px dashed #40916C; border-radius: 8px; background: #F0FAF3; color: #74C69D; font-size: 13px; min-height: 80px; }
#btnAjouterPlat, #btnAjouterCategorie { background-color: #2D6A4F; color: white; border: none; border-radius: 8px; padding: 9px 18px; font-size: 13px; font-weight: bold; }
#btnAjouterPlat:hover, #btnAjouterCategorie:hover { background-color: #1B4332; }
#btnModifierPlat, #btnModifierCategorie { background-color: #52B788; color: white; border: none; border-radius: 8px; padding: 9px 18px; font-size: 13px; font-weight: bold; }
#btnSupprimerPlat, #btnSupprimerCategorie { background-color: #E63946; color: white; border: none; border-radius: 8px; padding: 9px 18px; font-size: 13px; font-weight: bold; }
#btnToggleDisponible { background-color: #74C69D; color: white; border: none; border-radius: 8px; padding: 9px 18px; font-size: 13px; font-weight: bold; }
#btnChoisirImagePlat, #btnChoisirImageCategorie { background-color: #D8F3DC; color: #2D6A4F; border: 1.5px solid #74C69D; border-radius: 8px; padding: 7px 14px; font-size: 12px; font-weight: bold; }
#btnChangerStatut { background-color: #2D6A4F; color: white; border: none; border-radius: 8px; padding: 10px 24px; font-size: 14px; font-weight: bold; }
#btnChangerStatut:hover { background-color: #1B4332; }
#scrollAreaMenu { border: none; background: transparent; }
#scrollAreaWidgetContents { background: transparent; }
