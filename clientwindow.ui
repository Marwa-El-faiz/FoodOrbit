  <property name="styleSheet">
   <string notr="true">
QMainWindow{background-color:#F4F6F0;font-family:'Segoe UI',sans-serif;}
#sidebar{background-color:#2D6A4F;}
#lblLogoSidebar{color:#FFFFFF;font-size:20px;font-weight:bold;padding:10px;}
#lblSubtitle{color:#B7E4C7;font-size:11px;padding-bottom:6px;}
#lblNomClient{color:rgba(255,255,255,0.70);font-size:11px;padding-bottom:6px;}
#btnMenu,#btnPanier,#btnCommandes,#btnSuivi,#btnAvis,#btnProfil{
    background-color:transparent;color:#D8F3DC;border:none;
    text-align:left;padding:12px 20px;font-size:14px;border-radius:8px;margin:2px 8px;}
#btnMenu:hover,#btnPanier:hover,#btnCommandes:hover,
#btnSuivi:hover,#btnAvis:hover,#btnProfil:hover{background-color:#2D6A4F;color:#FFFFFF;}
#btnLogout{background-color:transparent;color:#FFB3B3;border:none;
    text-align:left;padding:12px 20px;font-size:13px;border-radius:8px;margin:2px 8px;}
#btnLogout:hover{background-color:#E63946;color:#FFFFFF;}
#headerMenu,#headerPanier,#headerCommandes,#headerSuivi,#headerAvis,#headerProfil{
    background-color:#2D6A4F;border-radius:10px;padding:5px;}
#lblTitreMenu,#lblTitrePanier,#lblTitreCommandes,#lblTitreSuivi,#lblTitreAvis,#lblTitreProfil{
    color:#FFFFFF;font-size:18px;font-weight:bold;padding-left:10px;}
#lblSousTitreMenu,#lblNbArticles,#lblSousTitreCommandes,
#lblTitreCommande,#lblSousTitreAvis,#lblSousTitreProfil{
    color:rgba(255,255,255,0.75);font-size:12px;padding-left:10px;}
#lineEditRecherche{border:1.5px solid #B7E4C7;border-radius:20px;
    padding:8px 18px;background:#FFFFFF;font-size:13px;color:#1B4332;}
#lineEditRecherche:focus{border-color:#2D6A4F;}
#btnPanierHeader{background:rgba(255,255,255,0.20);color:white;
    border-radius:20px;font-size:18px;border:2px solid rgba(255,255,255,0.30);}
#btnPanierHeader:hover{background:rgba(255,255,255,0.35);}
#frameCategoriesMenu{background:#FFFFFF;border-bottom:1px solid #D8EDDF;}
QScrollArea{background:transparent;border:none;}
QScrollBar:vertical{background:#E9F5EC;width:6px;border-radius:3px;}
QScrollBar::handle:vertical{background:#52B788;border-radius:3px;}
#frameTotal,#frameTemps,#frameEtapes,#frameDetailsSuivi,
#frameNoteMoyenne,#framePlatsTop,#frameSaisieAvis{
    background-color:#FFFFFF;border:1px solid #D8EDDF;border-radius:10px;}
#lblLabelSousTotal,#lblLabelLivraison{color:#74C69D;font-size:13px;}
#lblSousTotal,#lblFraisLivraison{color:#1B4332;font-size:13px;}
#lblLabelTotal{color:#1B4332;font-size:16px;font-weight:bold;}
#lblTotal{color:#2D6A4F;font-size:18px;font-weight:bold;}
#btnPasserCommande{background-color:#2D6A4F;color:white;border:none;
    border-radius:8px;padding:12px 24px;font-size:14px;font-weight:bold;}
#btnPasserCommande:hover{background-color:#1B4332;}
#lblTitreEtapes,#lblTitreDetails{font-size:14px;font-weight:bold;color:#1B4332;}
#lblTempsLabel{color:#74C69D;font-size:12px;}
#lblTempsValeur{color:#1B4332;font-size:20px;font-weight:bold;}
#lblTotalSuiviLabel{color:#1B4332;font-size:15px;font-weight:bold;}
#lblTotalSuivi{color:#2D6A4F;font-size:16px;font-weight:bold;}
#lblNoteMoyenne{font-size:52px;font-weight:bold;color:#1B4332;}
#lblEtoilesMoyenne{font-size:22px;color:#F4A100;}
#lblNbAvis{font-size:12px;color:rgba(255,255,255,0.80);}
#btnAvisRecents{background:#2D6A4F;color:white;border-radius:20px;
    padding:8px 20px;font-size:13px;font-weight:bold;border:none;}
#btnAvisMieuxNotes{background:transparent;color:#1B4332;border-radius:20px;
    padding:8px 20px;font-size:13px;font-weight:bold;border:none;}
#btnAvisMieuxNotes:hover{background:#E9F5EC;}
#btnSoumettreAvis,#btnContacterRestaurant{
    background-color:#2D6A4F;color:white;border:none;border-radius:10px;
    font-size:14px;font-weight:bold;padding:12px 24px;}
#btnSoumettreAvis:hover,#btnContacterRestaurant:hover{background-color:#1B4332;}
#lblNoteChoisie{color:#74C69D;font-size:13px;}
#textEditCommentaire{border:1.5px solid #D8EDDF;border-radius:10px;
    padding:10px;font-size:13px;color:#1B4332;background:#FAFFFE;}
#textEditCommentaire:focus{border-color:#2D6A4F;}
#leNom,#lePrenom,#leEmail,#leTelephone,#leAdresse,
#leMdpActuel,#leMdpNouveau,#leMdpConfirm{
    border:1px solid #D8EDDF;border-radius:10px;padding:0 14px;
    font-size:13px;color:#1B4332;background:#FAFFFE;min-height:40px;}
#leNom:focus,#lePrenom:focus,#leEmail:focus,
#leTelephone:focus,#leAdresse:focus,
#leMdpActuel:focus,#leMdpNouveau:focus,#leMdpConfirm:focus{
    border-color:#2D6A4F;background:#FFFFFF;
    border:1.5px solid #2D6A4F;}
#btnSauvegarderProfil{background:#2D6A4F;color:white;border:none;
    border-radius:10px;font-size:14px;font-weight:bold;padding:10px 28px;}
#btnSauvegarderProfil:hover{background:#1B4332;}
#btnChangerMdp{background:transparent;color:#2D6A4F;
    border:1.5px solid #2D6A4F;border-radius:10px;
    font-size:14px;font-weight:bold;padding:10px 28px;}
#btnChangerMdp:hover{background:#E8F5EE;}
#lblNomCompletProfil{font-size:17px;font-weight:bold;color:#1B4332;}
#lblEmailProfil{font-size:13px;color:#74C69D;}
#lblBadgeClient{background:#E8F5EE;color:#2D6A4F;border-radius:12px;
    font-size:12px;font-weight:bold;padding:4px 14px;}
#lblSectionInfos,#lblSectionMdp{font-size:11px;font-weight:bold;
    color:#2D6A4F;letter-spacing:1px;}
#frameMdpSection{background:#F4F9F6;}
